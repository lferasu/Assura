# Dependencies
/assistant/node_modules/
/mobile/node_modules/

# Local environment and secrets
/assistant/.env
/assistant/credentials.json
/assistant/token.json
/mobile/.env

# Generated runtime data
/assistant/data/*.jsonl
/assistant/data/state.json
/assistant/data/mobile-status.json
/assistant/data/expectations.json
/mobile/.expo/
/mobile/dist/

# Logs
*.log
npm-debug.log*

# Editor settings
/.vscode/*
!/.vscode/launch.json
/mobile/.idea/

# Accidental root-level npm artifacts
/package-lock.json
