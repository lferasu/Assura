{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Assura: Poll Runner",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/assistant",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "poll"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "envFile": "${workspaceFolder}/assistant/.env"
    }
  ]
}
